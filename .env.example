# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Mock mode ────────────────────────────────────────────────────────────────
# Set both to true to run the full pipeline with zero real API calls
USE_MOCK_LLM=false
USE_MOCK_PROVIDERS=false   # defaults to USE_MOCK_LLM if not set

# ── Tool layer (providers) ────────────────────────────────────────────────────
# Search provider — Perplexity Sonar API (https://docs.perplexity.ai)
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Company data provider — Crunchbase Basic API
# CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# Financial data provider — no key needed for yfinance (free)
# For Alpha Vantage: ALPHA_VANTAGE_API_KEY=your_key_here

# ── Optional LLM overrides ────────────────────────────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# MAX_TOKENS=8096
